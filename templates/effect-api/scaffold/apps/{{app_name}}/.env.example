# Database connection. Local dev value points at the docker-compose
# Postgres in this repo. Production sets via secrets manager.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/{{project_name}}_dev

# HTTP server port. Default 3000 if unset.
PORT=3000

# Log level: debug | info | warn | error. Default info.
LOG_LEVEL=info

# Optional - log format: pretty (dev) or json (production).
LOG_FORMAT=pretty
