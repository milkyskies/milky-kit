# Vite reads this from the app directory at dev/build time.
# Only variables prefixed with VITE_ are bundled into client code —
# anything else stays server-side. Treat all VITE_* values as PUBLIC
# (they end up in the JS bundle the browser downloads).

# URL the client hits for the API. In dev this is the wrangler dev port;
# in prod it's your deployed Worker domain.
VITE_API_URL=http://localhost:8787
