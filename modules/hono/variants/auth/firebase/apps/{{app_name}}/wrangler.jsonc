{
	"vars": {
		"FIREBASE_PROJECT_ID": "<your-firebase-project-id>"
	},
	"kv_namespaces": [
		{
			"binding": "JWK_CACHE",
			"id": "<run-wrangler-kv-namespace-create-{{project_name}}_jwk_cache>"
		},
		{
			"binding": "USER_CACHE",
			"id": "<run-wrangler-kv-namespace-create-{{project_name}}_user_cache>"
		}
	]
}
