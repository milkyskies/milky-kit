{
  "name": "{{project_name}}-api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply {{project_name}} --local",
    "db:migrate:remote": "wrangler d1 migrations apply {{project_name}} --remote"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "effect": "^3.20.0",
    "hono": "^4.12.10",
    "nanoid": "^5.1.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260404.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.7.0",
    "wrangler": "^4.4.0"
  }
}
