# drizzle-kit reads this via dotenv for migrations (run from your laptop).
# Local: docker-compose at the repo root.
DATABASE_URL=postgres://postgres:dev@localhost:5432/{{project_name}}

# Prod: set this to your Supabase pooler URL when running prod migrations.
# Get it from console.supabase.com -> Project Settings -> Database -> Connection pooling.
# Example: postgres://postgres.<project-ref>:<pw>@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres
