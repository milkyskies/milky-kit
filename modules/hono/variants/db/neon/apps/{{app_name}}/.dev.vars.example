# wrangler dev reads this for local Worker runtime env.
# Set DATABASE_URL to your Neon dev branch (or any Postgres URL).
DATABASE_URL = "postgres://<user>:<password>@<host>.neon.tech/<db>?sslmode=require"

# Local CORS origins — overrides wrangler.jsonc's prod value.
CORS_ORIGINS = "http://localhost:5173,capacitor://localhost"
